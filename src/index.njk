---
layout: base.njk
title: journal
---

<h1>journal</h1>
<p>notes, updates, logs, and random posts.</p>

{% for post in collections.post | reverse %}
  <div class="card">
    <div class="date">{{ post.date | readableDate }}</div>
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    <p>{{ post.data.description }}</p>
  </div>
{% endfor %}
